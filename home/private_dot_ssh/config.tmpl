# Machine-specific overrides (not in git) — must come first (first-match-wins)
{{ if eq .profile "home" -}}
Include ~/.ssh/config.local
{{ end -}}
Include ~/.colima/ssh_config

Host *
    AddKeysToAgent yes
    UseKeychain yes
    IdentitiesOnly yes
    HashKnownHosts yes
    ForwardAgent no
    ServerAliveInterval 60
    ServerAliveCountMax 3
